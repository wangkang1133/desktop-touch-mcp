# Native tool build artifacts (only the compiled .exe in bin/ is shipped)
bin/*.pdb
tools/win-ocr/bin/
tools/win-ocr/obj/

# vitest capture output (covers .vitest-out.txt / .vitest-out-e2e.txt / .vitest-out.json etc.)
.vitest-out*.txt
.vitest-out*.json
.vitest-verbose.txt
# vitest run sentinel (machine-local PID, e2e:stop mechanism)
.vitest-running

# cargo check / build output (captured for diagnostics)
.cargo-check-out.txt

# Ad-hoc test output and HTTP debug captures
_som-test-output.png
_http_test_stderr.txt
response_body.txt
response_headers.txt

# Smoke test working directories (npm cache, npx cache, run dir)
_smoke-npm-cache/
_smoke-npx-cache/
_smoke-run/

# MCP Registry publisher binary (downloaded locally, not distributed)
mcp-publisher.exe

# Ad-hoc working notes (captured remote commit lists, etc.)
